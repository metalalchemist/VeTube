#: run_main_window.py:32
msgid ""
"VeTube ya se encuentra en ejecución. Cierra la otra instancia antes de "
"iniciar esta."
msgstr ""
"VeTube sudah berjalan. Silahkan Tutup aplikasi ini sebelum menjalankan "
"aplikasi VeTube yang baru."

